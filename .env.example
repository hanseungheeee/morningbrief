# 환경 변수 예시 파일 - 실제 값은 .env 에 넣는다 (.env 는 git 제외)

# Finnhub 무료 API 키 (https://finnhub.io 가입 후 발급)
FINNHUB_API_KEY=

# Google Gemini API 키 (https://aistudio.google.com 에서 발급, 무료 티어) - 해설 생성용
GEMINI_API_KEY=

# 경제 캘린더(오늘 발표 지표 + 예정 일정)는 Nasdaq 무료 API 를 무키로 사용하므로
# 별도 키가 필요 없다. (Finnhub·FMP 무료 티어는 economic calendar 가 유료 전용)
