<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>미국 증시 아침 브리핑 - {{ date }}</title>
<style>
  /* 한국식 등락 색상: 상승=빨강, 하락=파랑, 보합=회색 */
  :root {
    --up: #e01e1e;
    --down: #1560d0;
    --flat: #888;
    --bg: #f4f5f7;
    --card: #ffffff;
    --text: #1a1a1a;
    --muted: #666;
    --border: #e3e5e9;
    /* 경제지표 예상 대비: 상회=주황, 하회=청록 (등락 색과 구분해 호/악재 오해 방지) */
    --sp-above: #c9761d;
    --sp-below: #2f8f83;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --up: #ff5b5b;
      --down: #5b9bff;
      --flat: #999;
      --bg: #15171c;
      --card: #1f2229;
      --text: #f0f0f2;
      --muted: #9aa0aa;
      --border: #2c3038;
      --sp-above: #e0913f;
      --sp-below: #4bb3a5;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 16px;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                 "Helvetica Neue", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
    line-height: 1.5;
    -webkit-text-size-adjust: 100%;
  }
  .wrap { max-width: 560px; margin: 0 auto; }

  /* 헤더 */
  header { text-align: center; margin-bottom: 20px; }
  header .date { font-size: 14px; color: var(--muted); }
  header h1 { font-size: 22px; margin: 4px 0 2px; }
  header .collected { font-size: 12px; color: var(--muted); }

  /* 브리핑 낭독 TTS 플레이어 (sticky) */
  .tts-bar {
    position: sticky;
    top: 0;
    z-index: 30;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 8px 10px;
    margin-bottom: 20px;
  }
  .tts-bar button {
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
    cursor: pointer;
  }
  .tts-bar button:hover:not(:disabled) { border-color: var(--sp-above); }
  .tts-bar button:disabled { opacity: 0.45; cursor: default; }
  .tts-bar select {
    font: inherit;
    font-size: 13px;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 5px 8px;
  }
  .tts-bar select:disabled { opacity: 0.45; }
  .tts-bar .tts-status {
    font-size: 13px;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    min-width: 34px;
    text-align: center;
  }
  .tts-bar .tts-voice { max-width: 150px; }
  .tts-bar .tts-note { font-size: 12px; color: var(--muted); }

  /* 현재 낭독 중인 블록 강조 */
  [data-tts].tts-active {
    outline: 2px solid var(--sp-above);
    outline-offset: 3px;
    border-radius: 8px;
  }

  /* 섹션 */
  section { margin-bottom: 22px; }
  section h2 {
    font-size: 15px;
    margin: 0 0 10px;
    padding-left: 8px;
    border-left: 4px solid var(--text);
  }

  /* 지수 카드 그리드 */
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 14px;
  }
  .card .label { font-size: 13px; color: var(--muted); }
  .card .price { font-size: 20px; font-weight: 700; margin: 4px 0 2px; }
  .card .chg { font-size: 13px; font-weight: 600; }

  /* 표 (매크로·암호화폐) */
  table { width: 100%; border-collapse: collapse; background: var(--card);
          border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  th, td { padding: 11px 14px; text-align: right; font-size: 14px; }
  th:first-child, td:first-child { text-align: left; }
  thead th { font-size: 12px; color: var(--muted); font-weight: 600;
             border-bottom: 1px solid var(--border); }
  tbody tr + tr td { border-top: 1px solid var(--border); }
  td .name { color: var(--text); }
  td .price { font-variant-numeric: tabular-nums; font-weight: 600; }

  /* 등락 색상 */
  .up { color: var(--up); }
  .down { color: var(--down); }
  .flat { color: var(--flat); }

  /* 오늘의 장 요약 블록 */
  .summary {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 22px;
  }
  .summary h2 { font-size: 15px; margin: 0 0 8px; }
  .summary p { margin: 0 0 10px; font-size: 14px; }
  .summary ul { margin: 0; padding-left: 18px; }
  .summary li { font-size: 13px; color: var(--muted); margin: 3px 0; }

  /* 섹션별 해설 (카드/표와 시각적으로 구분: 옅은 배경 + 작은 글씨 + 라벨) */
  .comment {
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(127, 127, 127, 0.08);
    border-left: 3px solid var(--flat);
    border-radius: 6px;
    font-size: 13px;
    color: var(--muted);
  }
  .comment .tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    margin-right: 6px;
  }

  /* 종목 코멘트 목록 (표 아래, 작은 글씨) */
  .stock-comments {
    margin: 10px 0 0;
    padding-left: 18px;
  }
  .stock-comments li {
    font-size: 13px;
    color: var(--muted);
    margin: 4px 0;
  }
  .stock-comments .ticker-name { font-weight: 700; color: var(--text); }
  .stock-comments .ticker-name.up { color: var(--up); }
  .stock-comments .ticker-name.down { color: var(--down); }

  /* 경제지표 예상 대비 배지 */
  .badge { font-size: 11px; font-weight: 700; margin-left: 6px; white-space: nowrap; }
  .badge.above { color: var(--sp-above); }
  .badge.below { color: var(--sp-below); }
  .badge.inline { color: var(--flat); }
  /* 예정 일정 날짜 셀 */
  td.cal-date { color: var(--muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.cal-cons { color: var(--muted); }

  /* 무버 상승/하락 소제목 */
  .mover-caption {
    font-size: 12px;
    font-weight: 700;
    margin: 12px 0 6px;
  }
  .mover-caption:first-of-type { margin-top: 0; }

  /* 오늘의 관전 포인트 (forward-looking) */
  .watch {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--sp-above);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 22px;
  }
  .watch h2 { font-size: 15px; margin: 0 0 8px; border: none; padding: 0; }
  .watch ul { margin: 0; padding-left: 18px; }
  .watch li { font-size: 13.5px; margin: 5px 0; }

  /* 시장 폭 (breadth) */
  .breadth {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 14px;
  }
  .breadth .bar { display: flex; height: 10px; border-radius: 5px;
                  overflow: hidden; margin: 9px 0 7px; background: var(--border); }
  .breadth .bar .up-seg { background: var(--up); }
  .breadth .bar .down-seg { background: var(--down); }
  .breadth .meta { font-size: 13px; color: var(--muted);
                   display: flex; justify-content: space-between; gap: 8px; }
  .breadth .meta .avg { font-weight: 700; }

  /* 주요 뉴스 목록 */
  .news-list { list-style: none; margin: 0; padding: 0 4px; }
  .news-list li { padding: 10px 0; border-top: 1px solid var(--border); font-size: 13.5px; }
  .news-list li:first-child { border-top: none; }
  .news-list a { color: var(--text); text-decoration: none; }
  .news-list a:hover { text-decoration: underline; }
  .news-list .src { display: block; font-size: 11px; color: var(--muted); margin-top: 3px; }

  footer { text-align: center; font-size: 11px; color: var(--muted); margin-top: 24px; }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="date">{{ date }}</div>
    <h1>미국 증시 아침 브리핑</h1>
    <div class="collected">수집 시각 {{ collected_at }}</div>
  </header>

  <!-- 브리핑 낭독 플레이어 (JS가 data-tts 블록·speechSynthesis 확인 후 노출) -->
  <div class="tts-bar" id="tts-bar" hidden>
    <button type="button" id="tts-toggle">▶ 재생</button>
    <button type="button" id="tts-stop">■ 정지</button>
    <span class="tts-status" id="tts-status">0/0</span>
    <select id="tts-rate" aria-label="낭독 속도">
      <option value="0.9">0.9배</option>
      <option value="1.0" selected>1.0배</option>
      <option value="1.2">1.2배</option>
      <option value="1.5">1.5배</option>
    </select>
    <select id="tts-voice" class="tts-voice" aria-label="음성 선택"></select>
    <span class="tts-note" id="tts-note" hidden></span>
  </div>

  <!-- 오늘의 장 요약 (해설 있을 때만) -->
  {% if commentary.market_summary or commentary.key_topics %}
  <div class="summary" data-tts="">
    <h2>오늘의 장 요약</h2>
    {% if commentary.market_summary %}<p>{{ commentary.market_summary }}</p>{% endif %}
    {% if commentary.key_topics %}
    <ul>
      {% for topic in commentary.key_topics %}
      <li>{{ topic }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endif %}

  <!-- 오늘의 관전 포인트 (forward-looking, 해설 있을 때만) -->
  {% if commentary.watch_points %}
  <div class="watch" data-tts="">
    <h2>오늘의 관전 포인트</h2>
    <ul>
      {% for wp in commentary.watch_points %}
      <li>{{ wp }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- 섹션1: 3대 지수 + 러셀2000 -->
  <section>
    <h2>주요 지수</h2>
    <div class="cards">
      {% for row in indices %}
      <div class="card">
        <div class="label">{{ row.name }}</div>
        <div class="price">{{ row.price }}</div>
        <div class="chg {{ row.direction }}">{{ row.change_pct }} ({{ row.change }})</div>
      </div>
      {% endfor %}
    </div>
    {% if commentary.index_comment %}
    <div class="comment" data-tts="주요 지수."><span class="tag">해설</span>{{ commentary.index_comment }}</div>
    {% endif %}
  </section>

  <!-- 시장 폭: 감시 유니버스 상승/하락 비율 (데이터 있을 때만) -->
  {% if breadth %}
  <section>
    <h2>시장 폭</h2>
    <div class="breadth">
      <div class="bar">
        <div class="up-seg" style="width: {{ breadth.up_pct }}%"></div>
        <div class="down-seg" style="width: {{ 100 - breadth.up_pct }}%"></div>
      </div>
      <div class="meta">
        <span>{{ breadth.total }}종목 중 <span class="up">상승 {{ breadth.up }}</span> · <span class="down">하락 {{ breadth.down }}</span> (상승 {{ breadth.up_pct }}%)</span>
        <span class="avg {{ breadth.direction }}">평균 {{ breadth.avg_change_pct }}</span>
      </div>
    </div>
  </section>
  {% endif %}

  <!-- 섹션2: 매크로 지표 -->
  <section>
    <h2>매크로 지표</h2>
    <table>
      <thead>
        <tr><th>지표</th><th>현재가</th><th>등락률</th><th>등락폭</th></tr>
      </thead>
      <tbody>
        {% for row in macros %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
          <td class="{{ row.direction }}">{{ row.change }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.macro_comment %}
    <div class="comment" data-tts="매크로 지표."><span class="tag">해설</span>{{ commentary.macro_comment }}</div>
    {% endif %}
  </section>

  <!-- 섹터 흐름: S&P 11개 섹터 ETF, 강→약 정렬 (데이터 있을 때만) -->
  {% if sectors %}
  <section>
    <h2>섹터 흐름 (강→약)</h2>
    <table>
      <thead>
        <tr><th>섹터</th><th>ETF 가격</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in sectors %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.sector_comment %}
    <div class="comment" data-tts="섹터 흐름."><span class="tag">해설</span>{{ commentary.sector_comment }}</div>
    {% endif %}
  </section>
  {% endif %}

  <!-- 연준·정책 해설 (정책 뉴스가 있는 날만) -->
  {% if commentary.policy_comment %}
  <section>
    <h2>연준·정책</h2>
    <div class="comment" data-tts="연준 및 정책."><span class="tag">해설</span>{{ commentary.policy_comment }}</div>
  </section>
  {% endif %}

  <!-- 경제 지표: 오늘 발표된 결과 (데이터 있을 때만) -->
  {% if calendar_today %}
  <section>
    <h2>오늘의 경제 지표</h2>
    <table>
      <thead>
        <tr><th>지표</th><th>실제</th><th>예상</th><th>이전</th></tr>
      </thead>
      <tbody>
        {% for e in calendar_today %}
        <tr>
          <td><span class="name">{{ e.name }}</span></td>
          <td class="price">{{ e.actual }}{% if e.surprise == 'above' %}<span class="badge above">▲상회</span>{% elif e.surprise == 'below' %}<span class="badge below">▼하회</span>{% elif e.surprise == 'inline' %}<span class="badge inline">부합</span>{% endif %}</td>
          <td>{{ e.consensus }}</td>
          <td>{{ e.previous }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.calendar_comment %}
    <div class="comment" data-tts="오늘의 경제 지표."><span class="tag">해설</span>{{ commentary.calendar_comment }}</div>
    {% endif %}
  </section>
  {% endif %}

  <!-- 경제 지표: 예정 일정 (데이터 있을 때만, 해설 없이 나열) -->
  {% if calendar_upcoming %}
  <section>
    <h2>예정 일정</h2>
    <table>
      <thead>
        <tr><th>날짜</th><th>지표</th><th>예상</th></tr>
      </thead>
      <tbody>
        {% for e in calendar_upcoming %}
        <tr>
          <td class="cal-date">{{ e.date }}</td>
          <td><span class="name">{{ e.name }}</span></td>
          <td class="cal-cons">{{ e.consensus }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- 섹션3: 암호화폐 -->
  <section>
    <h2>암호화폐 (USD)</h2>
    <table>
      <thead>
        <tr><th>코인</th><th>현재가</th><th>24h 등락률</th></tr>
      </thead>
      <tbody>
        {% for row in crypto %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.crypto_comment %}
    <div class="comment" data-tts="암호화폐."><span class="tag">해설</span>{{ commentary.crypto_comment }}</div>
    {% endif %}
  </section>

  <!-- 섹션4: 주요 종목 (데이터 있을 때만) -->
  {% if stocks %}
  <section>
    <h2>주요 종목</h2>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in stocks %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.stock_comments %}
    <ul class="stock-comments" data-tts="주요 종목.">
      {% for sc in commentary.stock_comments %}
      <li><span class="ticker-name">{{ sc.name }}</span> — {{ sc.comment }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  <!-- 섹션5: 오늘의 무버 (데이터 있을 때만) -->
  {% if mover_gainers or mover_losers %}
  <section>
    <h2>오늘의 무버</h2>
    {% if mover_gainers %}
    <div class="mover-caption up">상승</div>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in mover_gainers %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if mover_losers %}
    <div class="mover-caption down">하락</div>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in mover_losers %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if commentary.mover_comments %}
    <ul class="stock-comments" data-tts="오늘의 무버.">
      {% for mc in commentary.mover_comments %}
      <li><span class="ticker-name {{ mc.direction }}">{{ mc.name }}</span> — {{ mc.comment }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  <!-- 주요 뉴스: 실제 헤드라인 + 출처 링크 (데이터 있을 때만) -->
  {% if news %}
  <section>
    <h2>주요 뉴스</h2>
    <ul class="news-list">
      {% for n in news %}
      <li>
        {% if n.url %}<a href="{{ n.url }}" target="_blank" rel="noopener">{{ n.headline }}</a>{% else %}{{ n.headline }}{% endif %}
        {% if n.source %}<span class="src">{{ n.source }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <footer>미국 증시 아침 브리핑 · 자동 생성</footer>

</div>

<script>
(function () {
  'use strict';

  // 7. speechSynthesis 미지원 → 조용히 종료 (바는 hidden 유지)
  var synth = window.speechSynthesis;
  var bar = document.getElementById('tts-bar');
  if (!synth || !bar) return;

  // 낭독 대상: DOM(=querySelectorAll) 순서 그대로
  var blocks = Array.prototype.slice.call(document.querySelectorAll('[data-tts]'));
  if (blocks.length === 0) return;  // 산문 블록 0개 → 플레이어 숨김

  var toggleBtn = document.getElementById('tts-toggle');
  var stopBtn = document.getElementById('tts-stop');
  var statusEl = document.getElementById('tts-status');
  var rateSel = document.getElementById('tts-rate');
  var voiceSel = document.getElementById('tts-voice');
  var noteEl = document.getElementById('tts-note');

  // 크롬 데스크톱만 keepalive 대상 (사파리/모바일은 오히려 끊김)
  var ua = navigator.userAgent;
  var isChromeDesktop = /Chrome/.test(ua) && !/Mobile|Android|iPhone|iPad|iPod/.test(ua);

  // --- 텍스트 정규화 (낭독 직전) ---
  function normalize(text) {
    var t = String(text).replace(/\s+/g, ' ').trim();
    t = t.replace(/%/g, ' 퍼센트');
    t = t.replace(/\$/g, ' 달러');
    t = t.replace(/[▲▼]/g, '');            // ▲ ▼ 제거
    t = t.replace(/\+(?=\s*\d)/g, ' 플러스 ');        // 숫자 앞 +
    t = t.replace(/-(?=\s*\d)/g, ' 마이너스 ');        // 숫자 앞 -
    t = t.replace(/\s+/g, ' ').trim();
    return t;
  }

  // 1. 청크 분할: 문장 단위(lookbehind 미사용) + 200자 초과 시 공백 기준 추가 분할
  function chunkText(text) {
    var sentences = text.match(/[^.!?]+[.!?]*\s*/g) || [text];
    var out = [];
    for (var i = 0; i < sentences.length; i++) {
      var s = sentences[i].trim();
      if (!s) continue;
      if (s.length <= 200) { out.push(s); continue; }
      var words = s.split(' ');
      var cur = '';
      for (var j = 0; j < words.length; j++) {
        var next = cur ? cur + ' ' + words[j] : words[j];
        if (next.length > 200 && cur) {
          out.push(cur);
          cur = words[j];
        } else {
          cur = next;
        }
      }
      if (cur) out.push(cur);
    }
    return out;
  }

  // 블록별 낭독 계획: 각 청크가 어느 블록에 속하는지 기록
  var plan = [];
  blocks.forEach(function (block, bi) {
    var prefix = block.getAttribute('data-tts') || '';
    var full = (prefix ? prefix + ' ' : '') + block.textContent;
    var chunks = chunkText(normalize(full));
    if (chunks.length === 0) chunks = [prefix || ' '];
    chunks.forEach(function (c) { plan.push({ text: c, blockIndex: bi }); });
  });

  var pos = 0;
  var playing = false;
  var currentVoice = null;
  var koVoices = [];
  var keepalive = null;

  function startKeepalive() {
    if (!isChromeDesktop) return;
    stopKeepalive();
    keepalive = setInterval(function () {
      if (synth.speaking && !synth.paused) {
        synth.pause();
        synth.resume();
      }
    }, 10000);
  }
  function stopKeepalive() {
    if (keepalive) { clearInterval(keepalive); keepalive = null; }
  }

  function clearActive() {
    blocks.forEach(function (b) { b.classList.remove('tts-active'); });
  }
  function activateBlock(bi) {
    clearActive();
    var b = blocks[bi];
    if (b) {
      b.classList.add('tts-active');
      b.scrollIntoView({ block: 'center' });
    }
    statusEl.textContent = (bi + 1) + '/' + blocks.length;
  }

  function setPlayingUI(isPlaying) {
    toggleBtn.textContent = isPlaying ? '⏸ 일시정지' : '▶ 재생';
  }

  function speakCurrent() {
    if (pos >= plan.length) { finish(); return; }
    var item = plan[pos];
    // 새 블록 진입 시 강조 + 상태 갱신
    if (pos === 0 || plan[pos - 1].blockIndex !== item.blockIndex) {
      activateBlock(item.blockIndex);
    }
    var u = new SpeechSynthesisUtterance(item.text);
    u.lang = (currentVoice && currentVoice.lang) || 'ko-KR';
    if (currentVoice) u.voice = currentVoice;
    u.rate = parseFloat(rateSel.value) || 1.0;
    u.onend = function () {
      if (!playing) return;
      pos += 1;
      speakCurrent();
    };
    u.onerror = function () {
      if (!playing) return;   // cancel()로 인한 오류는 무시
      pos += 1;
      speakCurrent();
    };
    synth.speak(u);
  }

  function finish() {
    playing = false;
    stopKeepalive();
    clearActive();
    setPlayingUI(false);
    pos = 0;
    statusEl.textContent = '완료';
  }

  // 5. iOS 사파리: speak()는 사용자 제스처(클릭) 안에서 첫 호출돼야 함
  function play() {
    if (!currentVoice) return;
    if (playing && synth.paused) {           // 일시정지 → 재개
      synth.resume();
      setPlayingUI(true);
      startKeepalive();
      return;
    }
    playing = true;
    if (synth.speaking || synth.pending) synth.cancel();
    if (pos >= plan.length) pos = 0;
    setPlayingUI(true);
    startKeepalive();
    speakCurrent();                          // 클릭 핸들러 내 동기 호출
  }

  function pauseTts() {
    synth.pause();
    setPlayingUI(false);
    stopKeepalive();
  }

  function stopTts() {
    playing = false;
    synth.cancel();
    stopKeepalive();
    pos = 0;
    clearActive();
    setPlayingUI(false);
    statusEl.textContent = '0/' + blocks.length;
  }

  toggleBtn.addEventListener('click', function () {
    if (playing && synth.speaking && !synth.paused) {
      pauseTts();
    } else {
      play();
    }
  });
  stopBtn.addEventListener('click', stopTts);

  rateSel.addEventListener('change', function () {
    // 재생 중이면 다음 청크부터 새 속도 적용 (현재 청크는 유지)
    rateSel.blur();
  });

  voiceSel.addEventListener('change', function () {
    for (var i = 0; i < koVoices.length; i++) {
      if (koVoices[i].voiceURI === voiceSel.value) { currentVoice = koVoices[i]; break; }
    }
  });

  // 3. voices 비동기 로딩: getVoices()가 처음엔 빈 배열 → onvoiceschanged로 재구성
  function refreshVoices() {
    var all = synth.getVoices() || [];
    // 4. lang이 'ko'로 시작하는 음성만
    koVoices = all.filter(function (v) { return /^ko/i.test(v.lang); });

    if (koVoices.length === 0) {
      // 4. 한국어 음성 없음 → 안내 후 비활성화
      noteEl.textContent = '이 브라우저는 한국어 음성이 없습니다';
      noteEl.hidden = false;
      voiceSel.hidden = true;
      toggleBtn.disabled = true;
      stopBtn.disabled = true;
      rateSel.disabled = true;
      currentVoice = null;
      return;
    }

    noteEl.hidden = true;
    voiceSel.hidden = false;
    toggleBtn.disabled = false;
    stopBtn.disabled = false;
    rateSel.disabled = false;

    voiceSel.innerHTML = '';
    koVoices.forEach(function (v) {
      var opt = document.createElement('option');
      opt.value = v.voiceURI;
      opt.textContent = v.name + ' (' + v.lang + ')';
      voiceSel.appendChild(opt);
    });

    // 기존 선택 유지, 없으면 첫 번째를 기본값
    var keep = null;
    if (currentVoice) {
      for (var i = 0; i < koVoices.length; i++) {
        if (koVoices[i].voiceURI === currentVoice.voiceURI) { keep = koVoices[i]; break; }
      }
    }
    currentVoice = keep || koVoices[0];
    voiceSel.value = currentVoice.voiceURI;
  }

  // 초기화
  statusEl.textContent = '0/' + blocks.length;
  bar.hidden = false;                        // 블록 있고 지원됨 → 노출
  refreshVoices();
  if (typeof synth.onvoiceschanged !== 'undefined') {
    synth.onvoiceschanged = refreshVoices;
  }

  // 6. 페이지 이탈 시 낭독 중단 (안 그러면 음성이 계속 남음)
  window.addEventListener('pagehide', function () { synth.cancel(); });
})();
</script>
</body>
</html>
