<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>미국 증시 아침 브리핑 - {{ date }}</title>
<style>
  /* 한국식 등락 색상: 상승=빨강, 하락=파랑, 보합=회색 */
  :root {
    --up: #e01e1e;
    --down: #1560d0;
    --flat: #888;
    --bg: #f4f5f7;
    --card: #ffffff;
    --text: #1a1a1a;
    --muted: #666;
    --border: #e3e5e9;
    /* 경제지표 예상 대비: 상회=주황, 하회=청록 (등락 색과 구분해 호/악재 오해 방지) */
    --sp-above: #c9761d;
    --sp-below: #2f8f83;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --up: #ff5b5b;
      --down: #5b9bff;
      --flat: #999;
      --bg: #15171c;
      --card: #1f2229;
      --text: #f0f0f2;
      --muted: #9aa0aa;
      --border: #2c3038;
      --sp-above: #e0913f;
      --sp-below: #4bb3a5;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 16px;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                 "Helvetica Neue", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
    line-height: 1.5;
    -webkit-text-size-adjust: 100%;
  }
  .wrap { max-width: 560px; margin: 0 auto; }

  /* 헤더 */
  header { text-align: center; margin-bottom: 20px; }
  header .date { font-size: 14px; color: var(--muted); }
  header h1 { font-size: 22px; margin: 4px 0 2px; }
  header .collected { font-size: 12px; color: var(--muted); }

  /* 섹션 */
  section { margin-bottom: 22px; }
  section h2 {
    font-size: 15px;
    margin: 0 0 10px;
    padding-left: 8px;
    border-left: 4px solid var(--text);
  }

  /* 지수 카드 그리드 */
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 14px;
  }
  .card .label { font-size: 13px; color: var(--muted); }
  .card .price { font-size: 20px; font-weight: 700; margin: 4px 0 2px; }
  .card .chg { font-size: 13px; font-weight: 600; }

  /* 표 (매크로·암호화폐) */
  table { width: 100%; border-collapse: collapse; background: var(--card);
          border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  th, td { padding: 11px 14px; text-align: right; font-size: 14px; }
  th:first-child, td:first-child { text-align: left; }
  thead th { font-size: 12px; color: var(--muted); font-weight: 600;
             border-bottom: 1px solid var(--border); }
  tbody tr + tr td { border-top: 1px solid var(--border); }
  td .name { color: var(--text); }
  td .price { font-variant-numeric: tabular-nums; font-weight: 600; }

  /* 등락 색상 */
  .up { color: var(--up); }
  .down { color: var(--down); }
  .flat { color: var(--flat); }

  /* 오늘의 장 요약 블록 */
  .summary {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 22px;
  }
  .summary h2 { font-size: 15px; margin: 0 0 8px; }
  .summary p { margin: 0 0 10px; font-size: 14px; }
  .summary ul { margin: 0; padding-left: 18px; }
  .summary li { font-size: 13px; color: var(--muted); margin: 3px 0; }

  /* 섹션별 해설 (카드/표와 시각적으로 구분: 옅은 배경 + 작은 글씨 + 라벨) */
  .comment {
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(127, 127, 127, 0.08);
    border-left: 3px solid var(--flat);
    border-radius: 6px;
    font-size: 13px;
    color: var(--muted);
  }
  .comment .tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    margin-right: 6px;
  }

  /* 종목 코멘트 목록 (표 아래, 작은 글씨) */
  .stock-comments {
    margin: 10px 0 0;
    padding-left: 18px;
  }
  .stock-comments li {
    font-size: 13px;
    color: var(--muted);
    margin: 4px 0;
  }
  .stock-comments .ticker-name { font-weight: 700; color: var(--text); }
  .stock-comments .ticker-name.up { color: var(--up); }
  .stock-comments .ticker-name.down { color: var(--down); }

  /* 경제지표 예상 대비 배지 */
  .badge { font-size: 11px; font-weight: 700; margin-left: 6px; white-space: nowrap; }
  .badge.above { color: var(--sp-above); }
  .badge.below { color: var(--sp-below); }
  .badge.inline { color: var(--flat); }
  /* 예정 일정 날짜 셀 */
  td.cal-date { color: var(--muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.cal-cons { color: var(--muted); }

  /* 무버 상승/하락 소제목 */
  .mover-caption {
    font-size: 12px;
    font-weight: 700;
    margin: 12px 0 6px;
  }
  .mover-caption:first-of-type { margin-top: 0; }

  footer { text-align: center; font-size: 11px; color: var(--muted); margin-top: 24px; }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="date">{{ date }}</div>
    <h1>미국 증시 아침 브리핑</h1>
    <div class="collected">수집 시각 {{ collected_at }}</div>
  </header>

  <!-- 오늘의 장 요약 (해설 있을 때만) -->
  {% if commentary.market_summary or commentary.key_topics %}
  <div class="summary">
    <h2>오늘의 장 요약</h2>
    {% if commentary.market_summary %}<p>{{ commentary.market_summary }}</p>{% endif %}
    {% if commentary.key_topics %}
    <ul>
      {% for topic in commentary.key_topics %}
      <li>{{ topic }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endif %}

  <!-- 섹션1: 3대 지수 + 러셀2000 -->
  <section>
    <h2>주요 지수</h2>
    <div class="cards">
      {% for row in indices %}
      <div class="card">
        <div class="label">{{ row.name }}</div>
        <div class="price">{{ row.price }}</div>
        <div class="chg {{ row.direction }}">{{ row.change_pct }} ({{ row.change }})</div>
      </div>
      {% endfor %}
    </div>
    {% if commentary.index_comment %}
    <div class="comment"><span class="tag">해설</span>{{ commentary.index_comment }}</div>
    {% endif %}
  </section>

  <!-- 섹션2: 매크로 지표 -->
  <section>
    <h2>매크로 지표</h2>
    <table>
      <thead>
        <tr><th>지표</th><th>현재가</th><th>등락률</th><th>등락폭</th></tr>
      </thead>
      <tbody>
        {% for row in macros %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
          <td class="{{ row.direction }}">{{ row.change }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.macro_comment %}
    <div class="comment"><span class="tag">해설</span>{{ commentary.macro_comment }}</div>
    {% endif %}
  </section>

  <!-- 연준·정책 해설 (정책 뉴스가 있는 날만) -->
  {% if commentary.policy_comment %}
  <section>
    <h2>연준·정책</h2>
    <div class="comment"><span class="tag">해설</span>{{ commentary.policy_comment }}</div>
  </section>
  {% endif %}

  <!-- 경제 지표: 오늘 발표된 결과 (데이터 있을 때만) -->
  {% if calendar_today %}
  <section>
    <h2>오늘의 경제 지표</h2>
    <table>
      <thead>
        <tr><th>지표</th><th>실제</th><th>예상</th><th>이전</th></tr>
      </thead>
      <tbody>
        {% for e in calendar_today %}
        <tr>
          <td><span class="name">{{ e.name }}</span></td>
          <td class="price">{{ e.actual }}{% if e.surprise == 'above' %}<span class="badge above">▲상회</span>{% elif e.surprise == 'below' %}<span class="badge below">▼하회</span>{% elif e.surprise == 'inline' %}<span class="badge inline">부합</span>{% endif %}</td>
          <td>{{ e.consensus }}</td>
          <td>{{ e.previous }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.calendar_comment %}
    <div class="comment"><span class="tag">해설</span>{{ commentary.calendar_comment }}</div>
    {% endif %}
  </section>
  {% endif %}

  <!-- 경제 지표: 예정 일정 (데이터 있을 때만, 해설 없이 나열) -->
  {% if calendar_upcoming %}
  <section>
    <h2>예정 일정</h2>
    <table>
      <thead>
        <tr><th>날짜</th><th>지표</th><th>예상</th></tr>
      </thead>
      <tbody>
        {% for e in calendar_upcoming %}
        <tr>
          <td class="cal-date">{{ e.date }}</td>
          <td><span class="name">{{ e.name }}</span></td>
          <td class="cal-cons">{{ e.consensus }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- 섹션3: 암호화폐 -->
  <section>
    <h2>암호화폐 (USD)</h2>
    <table>
      <thead>
        <tr><th>코인</th><th>현재가</th><th>24h 등락률</th></tr>
      </thead>
      <tbody>
        {% for row in crypto %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.crypto_comment %}
    <div class="comment"><span class="tag">해설</span>{{ commentary.crypto_comment }}</div>
    {% endif %}
  </section>

  <!-- 섹션4: 주요 종목 (데이터 있을 때만) -->
  {% if stocks %}
  <section>
    <h2>주요 종목</h2>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in stocks %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if commentary.stock_comments %}
    <ul class="stock-comments">
      {% for sc in commentary.stock_comments %}
      <li><span class="ticker-name">{{ sc.name }}</span> — {{ sc.comment }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  <!-- 섹션5: 오늘의 무버 (데이터 있을 때만) -->
  {% if mover_gainers or mover_losers %}
  <section>
    <h2>오늘의 무버</h2>
    {% if mover_gainers %}
    <div class="mover-caption up">상승</div>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in mover_gainers %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if mover_losers %}
    <div class="mover-caption down">하락</div>
    <table>
      <thead>
        <tr><th>종목명</th><th>현재가</th><th>등락률</th></tr>
      </thead>
      <tbody>
        {% for row in mover_losers %}
        <tr>
          <td><span class="name">{{ row.name }}</span></td>
          <td class="price">{{ row.price }}</td>
          <td class="{{ row.direction }}">{{ row.change_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if commentary.mover_comments %}
    <ul class="stock-comments">
      {% for mc in commentary.mover_comments %}
      <li><span class="ticker-name {{ mc.direction }}">{{ mc.name }}</span> — {{ mc.comment }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  <footer>미국 증시 아침 브리핑 · 자동 생성</footer>

</div>
</body>
</html>
